# --- Mantle RPC ---
# Public endpoint works for the demo; for production swap in Alchemy/QuickNode.
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_WS_URL=wss://ws.mantle.xyz
MANTLE_CHAIN_ID=5000

# --- Postgres (Neon, Railway, Supabase — anything Postgres) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Narrator (Venice / Z.ai GLM-5.1) ---
# Get a Venice key at https://venice.ai/sign-up. The default model is
# Z.ai's open-weights GLM-5.1, served on Venice with E2EE inference.
VENICE_API_KEY=
VENICE_MODEL=zai-org-glm-5-1

# --- Optional integrations ---
# Elfa AI — social mindshare / trending tokens.
# https://www.elfa.ai/api · free tier = 1000 credits/mo
ELFA_API_KEY=

# Nansen — wallet labels (deep-links work without a key; API key adds labels).
# https://docs.nansen.ai/api
NANSEN_API_KEY=

# --- Telegram ---
# Create a bot with @BotFather, then add it to a channel as admin.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Discord (optional) ---
DISCORD_WEBHOOK_URL=

# --- Indexer tuning ---
INDEXER_START_BLOCK=
INDEXER_BATCH_SIZE=100
INDEXER_POLL_MS=2000

# --- Detector tuning ---
PRICE_SPIKE_PCT=3.0
PRICE_SPIKE_WINDOW_MIN=15
VOLUME_SPIKE_SIGMA=3.0
WHALE_USD_THRESHOLD=250000
ALERT_COOLDOWN_MIN=10

# --- Agent identity (ERC-8004 contract on Mantle) ---
AGENT_IDENTITY_ADDRESS=
AGENT_TOKEN_ID=
DEPLOYER_PRIVATE_KEY=

# --- Server ---
LOG_LEVEL=info
