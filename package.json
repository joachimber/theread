{
  "name": "theread",
  "version": "0.1.0",
  "private": true,
  "description": "Mantle anomaly detector + smart-money narrator. Watches the chain, explains the why.",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx watch src/runner.ts",
    "start": "tsx src/runner.ts",
    "indexer": "tsx src/indexer/index.ts",
    "detector": "tsx src/detector/index.ts",
    "bot": "tsx src/bot/index.ts",
    "backfill": "tsx src/scripts/backfill.ts",
    "label": "tsx src/scripts/label-known-wallets.ts",
    "seed": "tsx src/scripts/seed-demo.ts",
    "register-agent": "tsx src/scripts/register-agent.ts",
    "db:push": "drizzle-kit push",
